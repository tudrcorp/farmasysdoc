# =============================================================================
# ENTORNO DE PRODUCCIÓN — Plantilla (Farmadoc)
#
# Uso en el servidor:
#   1. Copiar: cp .env.production.example .env
#   2. Editar .env con valores reales.
#   3. Generar clave: php artisan key:generate --force
#   4. Migrar / cache: php artisan migrate --force && php artisan config:cache && php artisan route:cache && php artisan view:cache
#
# No commitear el archivo .env con secretos.
# =============================================================================

APP_NAME=Farmadoc
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com

APP_TIMEZONE=America/Caracas

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=farmadoc_production
DB_USERNAME=farmadoc
DB_PASSWORD=

# Opcional SSL MySQL (ej. RDS / proveedor gestionado)
# MYSQL_ATTR_SSL_CA=/ruta/al/ca.pem

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.tu-dominio.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=farmadoc_prod

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Producción: use smtp, ses, mailgun, postmark, etc. (no "log")
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DOLAR_API_BASE_URL=https://ve.dolarapi.com
DOLAR_API_TIMEOUT=8

# Factura fiscal térmica
FISCAL_THERMAL_LINE_WIDTH=42
FISCAL_VES_USD_RATE=
FISCAL_PRINTER_SERIAL=ZZP0000000
FISCAL_EMITIDO_POR=FARMASYS
FISCAL_MH_FOOTER=MH

# Laravel Boost / herramientas de desarrollo (desactivar en producción)
BOOST_ENABLED=false
BOOST_BROWSER_LOGS_WATCHER=false

VITE_APP_NAME="${APP_NAME}"
