APP_NAME=Farmadoc
APP_ENV=local
APP_KEY=base64:q0rKML9pw+Fe5zuIExQfINNUeMa2Be5ohlD6Y1e6SE0=
APP_DEBUG=true
APP_URL=https://farmasysdoc.test

# Zona horaria (fechas/horas en la app). IANA: America/Caracas = Venezuela.
APP_TIMEZONE=America/Caracas

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database   

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DOLAR_API_BASE_URL=https://ve.dolarapi.com
DOLAR_API_TIMEOUT=8

# APIs Banco de Venezuela (conciliación, saldos, C2P, etc.) — ver config/bdv_conciliation.php y Filament «BDV — APIs (pruebas)»
# Pago Móvil / conciliación BDV: teléfono del comercio (solo dígitos; sin espacios recomendado)
TEL=

BDV_CONCILIATION_TIMEOUT=30
BDV_CONCILIATION_CONNECT_TIMEOUT=15
BDV_CONCILIATION_FORCE_IPV4=true
BDV_CONCILIATION_USER_AGENT="Farmadoc/1.0 (BDV API)"
# QA: usar SIEMPRE el host HTTPS de los manuales dummy (saldo, C2P, etc.). NO uses http://200.11.243.176:444 salvo indicación del banco (cURL 52 en rutas nuevas).
BDV_QA_BASE_URL=https://bdvconciliacionqa.banvenez.com:444
# Compat: IP MDU antigua en QA o en BDV_CONCILIATION_BASE_URL se sustituye por HTTPS en todos los endpoints salvo:
BDV_CONCILIATION_QA_BASE_URL=
BDV_QA_USE_LEGACY_IP_HOST=false
# Ranuras de clave QA (vacío = defaults del manual dummy en config)
BDV_QA_KEY_CONCILIATION=
BDV_QA_KEY_SUITE=
BDV_QA_KEY_LOTE=
BDV_CONCILIATION_QA_API_KEY=
# Producción (misma regla anti-IP legacy que QA si usas BDV_CONCILIATION_BASE_URL)
BDV_PRODUCTION_BASE_URL=
BDV_PRODUCTION_KEY_CONCILIATION=
BDV_PRODUCTION_KEY_SUITE=
BDV_PRODUCTION_KEY_LOTE=
BDV_CONCILIATION_BASE_URL=https://bdvconciliacion.banvenez.com:443
BDV_CONCILIATION_API_KEY=
# Path conciliación simple si el banco cambia versión
BDV_PATH_GET_MOVEMENT=/getMovement/v2

# Factura fiscal térmica (prueba / HKA, ACLAS, etc.)
FISCAL_THERMAL_LINE_WIDTH=42
FISCAL_VES_USD_RATE=
FISCAL_PRINTER_SERIAL=ZZP0000000
FISCAL_EMITIDO_POR=FARMASYS
FISCAL_MH_FOOTER=MH
# Tras registrar venta (caja o venta completada en Filament), abrir diálogo de impresión del navegador
FISCAL_AUTO_PRINT_ON_SALE=true

# IVA por defecto (%) si no hay fila en financial_settings; la tasa efectiva se edita en Filament «Administración financiera».
ORDERS_DEFAULT_VAT_RATE_PERCENT=16

VITE_APP_NAME="${APP_NAME}"

# Geocodificación (API reparto): dirección de entrega → lat/lng. Geocoding API en Google Cloud; clave restringida por IP del servidor.
# Geocoding API + Directions API (servidor). Alias: GOOGLE_API_KEY si no defines la de abajo.
GOOGLE_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=

# Obligatoria para el mapa de entrega en pedidos (Filament): solo Google Maps (Maps JS + Places + Geocoding). Restringe por referrer del admin.
GOOGLE_MAPS_BROWSER_API_KEY=

# Opcional: estilos de mapa vectorial (Map IDs en Google Cloud). Si vacío, mapa clásico raster.
# GOOGLE_MAPS_MAP_ID_LIGHT=
# GOOGLE_MAPS_MAP_ID_DARK=

# Proxy /geo/nominatim/* (OpenStreetMap): email opcional para User-Agent según política Nominatim.
# NOMINATIM_CONTACT_EMAIL=

# Respaldo si Nominatim limita (429): API Photon por defecto https://photon.komoot.io
# PHOTON_GEOCODER_URL=

# WhatsApp UltraMsg: notifica a administradores cuando Gerencia registra traslados.
# Ejemplo de URL base: https://api.ultramsg.com/instance117518
ULTRAMSG_ENABLED=false
ULTRAMSG_BASE_URL=https://api.ultramsg.com/instance117518
ULTRAMSG_TOKEN=
ULTRAMSG_TIMEOUT=15
# CSV opcional de teléfonos administradores (fallback), ej: +584120000000,+584140000000
ULTRAMSG_ADMIN_FALLBACK_PHONES=
