# URL base del backend Laravel (SIN barra final).
#
# --- Simulador iOS (Xcode en la Mac) ---
# Suele funcionar Herd con tu dominio .test:
# EXPO_PUBLIC_API_URL=https://farmasysdoc.test
# O artisan en loopback:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# --- Android o iPhone físico con Expo Go ---
# https://TU-PROYECTO.test y localhost NO sirven: el teléfono no ve el DNS/Herd de tu Mac.
# 1) Mac e iPhone en la MISMA Wi-Fi.
# 2) En la raíz del repo Laravel:
#    php artisan serve --host=0.0.0.0 --port=8000
# 3) IP de la Mac: Ajustes del Sistema → Red → Wi‑Fi → Detalles → "Dirección IP"
#    Ejemplo:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# 4) Reiniciar Metro para cargar el .env:
#    cd mobile/farmadelivery && npx expo start -c
#
# --- HTTPS público (opcional) ---
# Si necesitas TLS (p. ej. certificados), expón Laravel con ngrok / Cloudflare Tunnel
# y usa la URL https que te den aquí.

EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# Google Maps (misma clave puede usarse con restricciones por app iOS/Android):
# — Maps SDK for Android / Maps SDK for iOS (mapa nativo con PROVIDER_GOOGLE)
# — Directions API (polyline de la ruta en la app)
# En Laravel (.env) usa otra clave restringida por IP: GOOGLE_MAPS_SERVER_API_KEY (Geocoding API).
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
