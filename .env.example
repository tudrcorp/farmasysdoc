APP_NAME=Farmadoc
APP_ENV=local
APP_KEY=base64:q0rKML9pw+Fe5zuIExQfINNUeMa2Be5ohlD6Y1e6SE0=
APP_DEBUG=true
APP_URL=https://farmasysdoc.test

# Zona horaria (fechas/horas en la app). IANA: America/Caracas = Venezuela.
APP_TIMEZONE=America/Caracas

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database   

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DOLAR_API_BASE_URL=https://ve.dolarapi.com
DOLAR_API_TIMEOUT=8

# API Conciliación BDV — Pagomóvil (manual MDU-006). Un solo endpoint: POST /getMovement
BDV_CONCILIATION_TIMEOUT=30
BDV_CONCILIATION_CONNECT_TIMEOUT=15
BDV_CONCILIATION_FORCE_IPV4=true
BDV_CONCILIATION_USER_AGENT="Farmadoc/1.0 (BDV Conciliation MDU-006)"
BDV_CONCILIATION_QA_BASE_URL=http://200.11.243.176:444
# Opcional: si vacío, config usa la clave de pruebas del manual
BDV_CONCILIATION_QA_API_KEY=
BDV_CONCILIATION_BASE_URL=https://bdvconciliacion.banvenez.com:443
# Obligatoria para ?environment=production (BDVenLínea Empresa)
BDV_CONCILIATION_API_KEY=

# Factura fiscal térmica (prueba / HKA, ACLAS, etc.)
FISCAL_THERMAL_LINE_WIDTH=42
FISCAL_VES_USD_RATE=
FISCAL_PRINTER_SERIAL=ZZP0000000
FISCAL_EMITIDO_POR=FARMASYS
FISCAL_MH_FOOTER=MH

VITE_APP_NAME="${APP_NAME}"
